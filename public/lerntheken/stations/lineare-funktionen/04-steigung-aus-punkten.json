  "hilfen": [],
  "hasSol": true,
  "task_html": "<div class=\"task-block task-blue\">\n  <div class=\"task-block-label\">Info: Steigung aus zwei Punkten</div>\n  <p style=\"font-size:14px;line-height:1.7;margin:0 0 8px 0;\">Wenn zwei Punkte P<sub>1</sub>(x<sub>1</sub>&nbsp;|&nbsp;y<sub>1</sub>) und P<sub>2</sub>(x<sub>2</sub>&nbsp;|&nbsp;y<sub>2</sub>) bekannt sind, gilt:</p>\n  <p style=\"text-align:center;font-family:'DM Mono',monospace;font-size:15px;font-weight:800;margin:8px 0;\">m = (y&#x2082; &minus; y&#x2081;) &divide; (x&#x2082; &minus; x&#x2081;)</p>\n</div>\n\n<p style=\"font-size:14px;margin:14px 0 8px 0;\"><strong>Aufgabe:</strong> Berechne die Steigung der Geraden durch die beiden Punkte.</p>\n\n<div class=\"tbl-wrap\">\n  <table>\n    <thead><tr><th style=\"background:#2563eb;\">Punkt P&#x2081;</th><th style=\"background:#2563eb;\">Punkt P&#x2082;</th><th style=\"background:#2563eb;\">Steigung m</th></tr></thead>\n    <tbody>\n      <tr><td class=\"given\">(0 | 1)</td><td class=\"given\">(2 | 5)</td><td><input class=\"cell-input\" data-ans=\"2\" placeholder=\"?\"></td></tr>\n      <tr><td class=\"given\">(1 | 3)</td><td class=\"given\">(4 | 9)</td><td><input class=\"cell-input\" data-ans=\"2\" placeholder=\"?\"></td></tr>\n      <tr><td class=\"given\">(0 | 4)</td><td class=\"given\">(2 | 0)</td><td><input class=\"cell-input\" data-ans=\"-2\" placeholder=\"?\"></td></tr>\n      <tr><td class=\"given\">(&minus;2 | 1)</td><td class=\"given\">(4 | 4)</td><td><input class=\"cell-input\" data-ans=\"0.5\" placeholder=\"?\"></td></tr>\n      <tr><td class=\"given\">(1 | &minus;2)</td><td class=\"given\">(3 | 4)</td><td><input class=\"cell-input\" data-ans=\"3\" placeholder=\"?\"></td></tr>\n    </tbody>\n  </table>\n</div>\n\n<div class=\"check-bar\">\n  <button class=\"btn-check\" onclick=\"checkStation(4)\">&#x2713; &#xDC;berpr&#xFC;fen</button>\n  <button class=\"btn-reset\" onclick=\"resetStation(4)\">&#x21BA; Zur&#xFC;cksetzen</button>\n  <span class=\"check-result\" id=\"check-result-4\"></span>\n</div>",
  "sol_html": "<div style=\"font-family:'DM Mono',monospace;font-size:13px;line-height:2.2;\">\n  (5&minus;1)&divide;(2&minus;0) = <strong>2</strong><br>\n  (9&minus;3)&divide;(4&minus;1) = <strong>2</strong><br>\n  (0&minus;4)&divide;(2&minus;0) = <strong>&minus;2</strong><br>\n  (4&minus;1)&divide;(4&minus;(&minus;2)) = 3&divide;6 = <strong>0,5</strong><br>\n  (4&minus;(&minus;2))&divide;(3&minus;1) = 6&divide;2 = <strong>3</strong>\n</div>"
}
