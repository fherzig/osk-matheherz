  "task_html": "<a href=\"https://www.youtube.com/watch?v=fGi3XPMnSVA\" target=\"_blank\" class=\"video-link-card\" style=\"margin-bottom:16px;\">\n  <div class=\"video-link-icon\">&#x25B6;</div>\n  <div class=\"video-link-text\">\n    <div class=\"video-link-title\">Steigung berechnen</div>\n    <div class=\"video-link-sub\">YouTube &middot; Steigungsdreieck und Steigungsformel</div>\n  </div>\n  <div class=\"video-link-arrow\">&#x2197;</div>\n</a>\n\n<div class=\"task-block task-blue\">\n  <div class=\"task-block-label\">Info: Steigungsdreieck</div>\n  <div style=\"display:flex;align-items:center;gap:20px;flex-wrap:wrap;\">\n    <svg viewBox=\"0 0 180 120\" style=\"width:160px;flex-shrink:0;\" xmlns=\"http://www.w3.org/2000/svg\">\n      <line x1=\"20\" y1=\"90\" x2=\"160\" y2=\"90\" stroke=\"#94a3b8\" stroke-width=\"1\"/>\n      <line x1=\"20\" y1=\"10\" x2=\"20\" y2=\"90\" stroke=\"#94a3b8\" stroke-width=\"1\"/>\n      <line x1=\"30\" y1=\"80\" x2=\"150\" y2=\"20\" stroke=\"#2563eb\" stroke-width=\"2.5\"/>\n      <line x1=\"30\" y1=\"80\" x2=\"150\" y2=\"80\" stroke=\"#dc2626\" stroke-width=\"2\" stroke-dasharray=\"4,3\"/>\n      <line x1=\"150\" y1=\"20\" x2=\"150\" y2=\"80\" stroke=\"#16a34a\" stroke-width=\"2\" stroke-dasharray=\"4,3\"/>\n      <text x=\"88\" y=\"96\" text-anchor=\"middle\" font-size=\"11\" fill=\"#dc2626\" font-family=\"monospace\" font-weight=\"bold\">Δx</text>\n      <text x=\"158\" y=\"54\" text-anchor=\"start\" font-size=\"11\" fill=\"#16a34a\" font-family=\"monospace\" font-weight=\"bold\">Δy</text>\n      <text x=\"55\" y=\"42\" font-size=\"11\" fill=\"#2563eb\" font-family=\"monospace\">m = Δy/Δx</text>\n    </svg>\n    <div style=\"font-size:14px;line-height:1.8;\">\n      <strong>Steigung m</strong> = H&#xF6;henunterschied &divide; Streckenunterschied<br>\n      <span style=\"font-family:'DM Mono',monospace;font-size:16px;font-weight:800;\">m = &Delta;y / &Delta;x</span>\n    </div>\n  </div>\n</div>\n\n<p style=\"font-size:14px;margin:14px 0 8px 0;\"><strong>Aufgabe:</strong> Berechne die Steigung m.</p>\n\n<div class=\"tbl-wrap\">\n  <table>\n    <thead><tr><th style=\"background:#d95f2b;\">&Delta;y (H&#xF6;he)</th><th style=\"background:#d95f2b;\">&Delta;x (Strecke)</th><th style=\"background:#d95f2b;\">Steigung m</th></tr></thead>\n    <tbody>\n      <tr><td class=\"given\">3</td><td class=\"given\">6</td><td><input class=\"cell-input\" data-ans=\"0.5\" placeholder=\"?\"></td></tr>\n      <tr><td class=\"given\">4</td><td class=\"given\">2</td><td><input class=\"cell-input\" data-ans=\"2\" placeholder=\"?\"></td></tr>\n      <tr><td class=\"given\">&minus;3</td><td class=\"given\">6</td><td><input class=\"cell-input\" data-ans=\"-0.5\" placeholder=\"?\"></td></tr>\n      <tr><td class=\"given\">5</td><td class=\"given\">4</td><td><input class=\"cell-input\" data-ans=\"1.25\" placeholder=\"?\"></td></tr>\n    </tbody>\n  </table>\n</div>\n\n<div class=\"check-bar\">\n  <button class=\"btn-check\" onclick=\"checkStation(1)\">&#x2713; &#xDC;berpr&#xFC;fen</button>\n  <button class=\"btn-reset\" onclick=\"resetStation(1)\">&#x21BA; Zur&#xFC;cksetzen</button>\n  <span class=\"check-result\" id=\"check-result-1\"></span>\n</div>",
