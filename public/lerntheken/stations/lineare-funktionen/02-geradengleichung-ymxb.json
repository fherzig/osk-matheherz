  "task_html": "<a href=\"https://www.youtube.com/watch?v=3Ifbc736yfY\" target=\"_blank\" class=\"video-link-card\" style=\"margin-bottom:16px;\">\n  <div class=\"video-link-icon\">&#x25B6;</div>\n  <div class=\"video-link-text\">\n    <div class=\"video-link-title\">Zuordnungsvorschrift f&#xFC;r Geraden</div>\n    <div class=\"video-link-sub\">YouTube &middot; y = mx + b verstehen und anwenden</div>\n  </div>\n  <div class=\"video-link-arrow\">&#x2197;</div>\n</a>\n\n<div class=\"task-block task-blue\">\n  <div class=\"task-block-label\">Info: y = mx + b</div>\n  <div style=\"display:flex;align-items:center;gap:20px;flex-wrap:wrap;\">\n    <svg viewBox=\"0 0 160 140\" style=\"width:130px;flex-shrink:0;\" xmlns=\"http://www.w3.org/2000/svg\">\n      <line x1=\"10\" y1=\"70\" x2=\"150\" y2=\"70\" stroke=\"#94a3b8\" stroke-width=\"1\"/>\n      <line x1=\"80\" y1=\"10\" x2=\"80\" y2=\"130\" stroke=\"#94a3b8\" stroke-width=\"1\"/>\n      <line x1=\"20\" y1=\"110\" x2=\"145\" y2=\"30\" stroke=\"#2563eb\" stroke-width=\"2.5\"/>\n      <circle cx=\"80\" cy=\"64\" r=\"4\" fill=\"#d97706\"/>\n      <text x=\"84\" y=\"60\" font-size=\"10\" fill=\"#d97706\" font-family=\"monospace\" font-weight=\"bold\">b</text>\n      <text x=\"95\" y=\"44\" font-size=\"10\" fill=\"#2563eb\" font-family=\"monospace\">m = Steigung</text>\n    </svg>\n    <div style=\"font-size:14px;line-height:1.8;\">\n      <span style=\"font-family:'DM Mono',monospace;font-size:16px;font-weight:800;\">y = mx + b</span><br>\n      <strong>m</strong> = Steigung<br>\n      <strong>b</strong> = y-Achsenabschnitt\n    </div>\n  </div>\n</div>\n\n<p style=\"font-size:14px;margin:14px 0 8px 0;\"><strong>Aufgabe:</strong> Bestimme Steigung m und y-Achsenabschnitt b.</p>\n\n<div class=\"tbl-wrap\">\n  <table>\n    <thead><tr><th style=\"background:#d95f2b;\">Gleichung</th><th style=\"background:#d95f2b;\">m</th><th style=\"background:#d95f2b;\">b</th></tr></thead>\n    <tbody>\n      <tr><td class=\"given\">f(x) = 2x + 3</td><td><input class=\"cell-input\" data-ans=\"2\" placeholder=\"m\"></td><td><input class=\"cell-input\" data-ans=\"3\" placeholder=\"b\"></td></tr>\n      <tr><td class=\"given\">g(x) = &minus;x + 5</td><td><input class=\"cell-input\" data-ans=\"-1\" placeholder=\"m\"></td><td><input class=\"cell-input\" data-ans=\"5\" placeholder=\"b\"></td></tr>\n      <tr><td class=\"given\">h(x) = 0,5x &minus; 2</td><td><input class=\"cell-input\" data-ans=\"0.5\" placeholder=\"m\"></td><td><input class=\"cell-input\" data-ans=\"-2\" placeholder=\"b\"></td></tr>\n      <tr><td class=\"given\">k(x) = 3x</td><td><input class=\"cell-input\" data-ans=\"3\" placeholder=\"m\"></td><td><input class=\"cell-input\" data-ans=\"0\" placeholder=\"b\"></td></tr>\n      <tr><td class=\"given\">l(x) = &minus;4</td><td><input class=\"cell-input\" data-ans=\"0\" placeholder=\"m\"></td><td><input class=\"cell-input\" data-ans=\"-4\" placeholder=\"b\"></td></tr>\n    </tbody>\n  </table>\n</div>\n\n<div class=\"check-bar\">\n  <button class=\"btn-check\" onclick=\"checkStation(2)\">&#x2713; &#xDC;berpr&#xFC;fen</button>\n  <button class=\"btn-reset\" onclick=\"resetStation(2)\">&#x21BA; Zur&#xFC;cksetzen</button>\n  <span class=\"check-result\" id=\"check-result-2\"></span>\n</div>",
  "sol_html": "<table style=\"font-family:'DM Mono',monospace;font-size:13px;border-collapse:collapse;width:100%;\">\n  <tr><td style=\"padding:4px 8px;\">f(x)=2x+3:</td><td style=\"padding:4px 8px;\">m=<strong>2</strong>, b=<strong>3</strong></td></tr>\n  <tr><td style=\"padding:4px 8px;\">g(x)=&minus;x+5:</td><td style=\"padding:4px 8px;\">m=<strong>&minus;1</strong>, b=<strong>5</strong></td></tr>\n  <tr><td style=\"padding:4px 8px;\">h(x)=0,5x&minus;2:</td><td style=\"padding:4px 8px;\">m=<strong>0,5</strong>, b=<strong>&minus;2</strong></td></tr>\n  <tr><td style=\"padding:4px 8px;\">k(x)=3x:</td><td style=\"padding:4px 8px;\">m=<strong>3</strong>, b=<strong>0</strong></td></tr>\n  <tr><td style=\"padding:4px 8px;\">l(x)=&minus;4:</td><td style=\"padding:4px 8px;\">m=<strong>0</strong>, b=<strong>&minus;4</strong></td></tr>\n</table>"
